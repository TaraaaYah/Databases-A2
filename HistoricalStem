SELECT e.event_title, e.event_date,
       s.full_name        AS scientist_topic,
       sp.first_name      AS speaker,
       r.room_name,
       r.room_type,
       CASE e.requires_ticket WHEN TRUE THEN 'Yes' ELSE 'No' END AS ticketed
FROM Event e
JOIN Event_HistoricalFigure ehf ON e.event_id = ehf.event_id
JOIN Scientist s   ON ehf.scientist_id = s.scientist_id
