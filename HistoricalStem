-- ============================================================
-- Assessment 2: Historical STEM Figures Database
-- 3rd Normal Form (3NF) Normalised Database
-- Compatible with MySQL / MariaDB
-- ============================================================

-- ============================================================
-- SECTION 1: DROP TABLES (clean slate)
-- Dropped in reverse dependency order to avoid FK violations
-- ============================================================
DROP TABLE IF EXISTS Event_HistoricalFigure;
DROP TABLE IF EXISTS Event_Speaker;
DROP TABLE IF EXISTS Event_Room;
DROP TABLE IF EXISTS Ticket;
DROP TABLE IF EXISTS Event;
DROP TABLE IF EXISTS Room;
DROP TABLE IF EXISTS Speaker;
DROP TABLE IF EXISTS Scientist_Field;
DROP TABLE IF EXISTS Scientist_Organisation;
DROP TABLE IF EXISTS Scientist;
DROP TABLE IF EXISTS Field;
DROP TABLE IF EXISTS Organisation;
DROP TABLE IF EXISTS Country;


-- ============================================================
-- SECTION 2: CREATE LOOKUP / REFERENCE TABLES
-- These hold atomic values; referenced by foreign key only.
-- Moving country, field and organisation into their own tables
-- removes repeating groups and transitive dependencies (3NF).
-- ============================================================

-- Country: each country stored once and referenced by ID
CREATE TABLE Country (
    country_id   INT          AUTO_INCREMENT PRIMARY KEY,
    country_name VARCHAR(100) NOT NULL UNIQUE
);

-- Field of study: normalised out of Scientist to remove the
-- comma-separated repeating group (e.g. "Mathematics, Computing")
CREATE TABLE Field (
    field_id   INT          AUTO_INCREMENT PRIMARY KEY,
    field_name VARCHAR(100) NOT NULL UNIQUE
);

-- Organisation: employers / institutions stored separately
-- prevents transitive dependency in the Scientist table
CREATE TABLE Organisation (
    org_id   INT          AUTO_INCREMENT PRIMARY KEY,
    org_name VARCHAR(200) NOT NULL UNIQUE
);


-- ============================================================
-- SECTION 3: SCIENTIST TABLE (core biographical data)
-- All non-key attributes depend solely on scientist_id (3NF).
-- death_year is NULL for scientists who are still alive.
-- ============================================================
CREATE TABLE Scientist (
    scientist_id INT          AUTO_INCREMENT PRIMARY KEY,
    full_name    VARCHAR(200) NOT NULL,
    birth_year   INT,
    death_year   INT,
    country_id   INT          NOT NULL,
    biography    TEXT,
    CONSTRAINT fk_scientist_country FOREIGN KEY (country_id)
        REFERENCES Country(country_id)
);


-- ============================================================
-- SECTION 4: JUNCTION TABLES (many-to-many relationships)
-- A junction table is required wherever a many-to-many
-- relationship exists, to achieve 3NF.
-- ============================================================

-- Scientist <-> Field (a scientist can cover many fields; a field
-- can have many scientists)
CREATE TABLE Scientist_Field (
    scientist_id INT NOT NULL,
    field_id     INT NOT NULL,
    PRIMARY KEY (scientist_id, field_id),
    CONSTRAINT fk_sf_scientist FOREIGN KEY (scientist_id)
        REFERENCES Scientist(scientist_id),
    CONSTRAINT fk_sf_field FOREIGN KEY (field_id)
        REFERENCES Field(field_id)
);

-- Scientist <-> Organisation (a scientist can work for many orgs;
-- an org can employ many scientists)
CREATE TABLE Scientist_Organisation (
    scientist_id INT NOT NULL,
    org_id       INT NOT NULL,
    PRIMARY KEY (scientist_id, org_id),
    CONSTRAINT fk_so_scientist FOREIGN KEY (scientist_id)
        REFERENCES Scientist(scientist_id),
    CONSTRAINT fk_so_org FOREIGN KEY (org_id)
        REFERENCES Organisation(org_id)
);


-- ============================================================
-- SECTION 5: EVENTS / BOOKING SYSTEM
-- Requirements: events have at least 1 speaker, 1 or more
-- historical figures as topics, and 1 or more rooms.
-- Ticket information is separated to avoid NULLs on free events.
-- ============================================================

-- Speaker: people who deliver talks at events
CREATE TABLE Speaker (
    speaker_id  INT          AUTO_INCREMENT PRIMARY KEY,
    first_name  VARCHAR(100) NOT NULL,
    last_name   VARCHAR(100) NOT NULL,
    email       VARCHAR(200),
    affiliation VARCHAR(200)
);

-- Room: venues for events. Two types as per brief.
CREATE TABLE Room (
    room_id    INT          AUTO_INCREMENT PRIMARY KEY,
    room_name  VARCHAR(100) NOT NULL,
    room_type  ENUM('Lecture', 'Event') NOT NULL,
    capacity   INT          NOT NULL,
    location   VARCHAR(200)
);

-- Event: core event record
CREATE TABLE Event (
    event_id        INT           AUTO_INCREMENT PRIMARY KEY,
    event_title     VARCHAR(300)  NOT NULL,
    event_date      DATE          NOT NULL,
    start_time      TIME,
    end_time        TIME,
    description     TEXT,
    requires_ticket BOOLEAN       NOT NULL DEFAULT FALSE
);

-- Ticket: stored separately so free events have no orphan NULLs
CREATE TABLE Ticket (
    ticket_id   INT           AUTO_INCREMENT PRIMARY KEY,
    event_id    INT           NOT NULL UNIQUE,
    price       DECIMAL(6,2)  NOT NULL,
    total_seats INT           NOT NULL,
    CONSTRAINT fk_ticket_event FOREIGN KEY (event_id)
        REFERENCES Event(event_id)
);

-- Event <-> Room (an event needs at least 1 room; a room can
-- host many events)
CREATE TABLE Event_Room (
    event_id INT NOT NULL,
    room_id  INT NOT NULL,
    PRIMARY KEY (event_id, room_id),
    CONSTRAINT fk_er_event FOREIGN KEY (event_id)
        REFERENCES Event(event_id),
    CONSTRAINT fk_er_room  FOREIGN KEY (room_id)
        REFERENCES Room(room_id)
);

-- Event <-> Speaker (at least 1 speaker per event)
CREATE TABLE Event_Speaker (
    event_id   INT          NOT NULL,
    speaker_id INT          NOT NULL,
    role       VARCHAR(100) DEFAULT 'Speaker',
    PRIMARY KEY (event_id, speaker_id),
    CONSTRAINT fk_es_event   FOREIGN KEY (event_id)
        REFERENCES Event(event_id),
    CONSTRAINT fk_es_speaker FOREIGN KEY (speaker_id)
        REFERENCES Speaker(speaker_id)
);

-- Event <-> HistoricalFigure (1 or more topics per event)
CREATE TABLE Event_HistoricalFigure (
    event_id     INT NOT NULL,
    scientist_id INT NOT NULL,
    PRIMARY KEY (event_id, scientist_id),
    CONSTRAINT fk_ehf_event     FOREIGN KEY (event_id)
        REFERENCES Event(event_id),
    CONSTRAINT fk_ehf_scientist FOREIGN KEY (scientist_id)
        REFERENCES Scientist(scientist_id)
);


