-- ────────────────────────────────────────────────────────────
-- Query 1: List all historical figures born in France
-- ────────────────────────────────────────────────────────────
SELECT s.full_name, s.birth_year, s.death_year
FROM Scientist s
JOIN Country c ON s.country_id = c.country_id
WHERE c.country_name = 'France'
ORDER BY s.birth_year;
-- Results: Émilie du Châtelet, Marie-Sophie Germain,
--          Irène Joliot-Curie, Yvonne Choquet-Bruhat

-- ────────────────────────────────────────────────────────────
-- Query 2: List all historical figures that contributed to Computing
-- ────────────────────────────────────────────────────────────
SELECT s.full_name, s.birth_year, s.death_year
FROM Scientist s
JOIN Scientist_Field sf ON s.scientist_id = sf.scientist_id
JOIN Field f ON sf.field_id = f.field_id
WHERE f.field_name = 'Computing'
ORDER BY s.full_name;
-- Results: Augusta Ada King (Lovelace), Fumiko Yonezawa, Grace Hopper

-- ────────────────────────────────────────────────────────────
-- Query 3: List all historical figures that contributed to more than 1 field
-- ────────────────────────────────────────────────────────────
SELECT s.full_name, COUNT(sf.field_id) AS field_count
FROM Scientist s
JOIN Scientist_Field sf ON s.scientist_id = sf.scientist_id
GROUP BY s.scientist_id, s.full_name
HAVING COUNT(sf.field_id) > 1
ORDER BY field_count DESC, s.full_name;
-- Results: Hertha Ayrton (3), Sophia Brahe (3), and 13 others with 2 fields

-- ────────────────────────────────────────────────────────────
-- Query 4: Mary Jackson's death year is incorrectly listed.
--          Update this date to 2005.
-- ────────────────────────────────────────────────────────────
UPDATE Scientist
SET death_year = 2005
WHERE full_name = 'Mary Jackson';
-- Verify:
SELECT full_name, birth_year, death_year FROM Scientist
WHERE full_name = 'Mary Jackson';
-- Result: Mary Jackson | 1921 | 2005

-- ────────────────────────────────────────────────────────────
-- Query 5: List all historical figures who died before they were 40
-- ────────────────────────────────────────────────────────────
SELECT full_name, birth_year, death_year,
       (death_year - birth_year) AS age_at_death
FROM Scientist
WHERE death_year IS NOT NULL
  AND (death_year - birth_year) < 40
ORDER BY age_at_death;
-- Results: Augusta Ada King (Lovelace, 37), Rosalind Franklin (38)

-- ────────────────────────────────────────────────────────────
-- Query 6: Which countries have the most historical figures listed?
-- ────────────────────────────────────────────────────────────
SELECT c.country_name, COUNT(s.scientist_id) AS figure_count
FROM Country c
JOIN Scientist s ON c.country_id = s.country_id
GROUP BY c.country_id, c.country_name
ORDER BY figure_count DESC;
-- Results: Britain (5), USA (4), France (4), Germany (3), ...

-- ────────────────────────────────────────────────────────────
-- Query 7: Are any historical figures still alive? If so who?
-- (NULL death_year indicates the figure is still alive)
-- ────────────────────────────────────────────────────────────
SELECT full_name, birth_year
FROM Scientist
WHERE death_year IS NULL
ORDER BY birth_year;
-- Result: Yvonne Choquet-Bruhat (born 1923)

-- ────────────────────────────────────────────────────────────
-- Query 8: Which historical figures worked for NASA?
-- ────────────────────────────────────────────────────────────
SELECT s.full_name, s.birth_year, s.death_year
FROM Scientist s
JOIN Scientist_Organisation so ON s.scientist_id = so.scientist_id
JOIN Organisation o ON so.org_id = o.org_id
WHERE o.org_name = 'NASA'
ORDER BY s.full_name;
-- Results: Katherine Johnson, Mary Jackson

-- ────────────────────────────────────────────────────────────
-- Query 9: Which historical figures worked with Einstein?
-- Three figures are documented to have worked directly with Einstein:
-- - Mileva Marić  : studied alongside Einstein at Zurich Polytechnic;
--                   debated collaborator on his 1905 papers
-- - Emmy Noether  : her theorem directly resolved a flaw in Einstein's
--                   General Relativity equations
-- - Yvonne Choquet-Bruhat: worked with Einstein on the vacuum field
--                   equations, beginning the field of GR dynamics
-- ────────────────────────────────────────────────────────────
SELECT s.full_name, s.birth_year, s.death_year,
       c.country_name AS country_of_birth
FROM Scientist s
JOIN Country c ON s.country_id = c.country_id
WHERE s.full_name IN ('Mileva Marić', 'Yvonne Choquet-Bruhat', 'Emmy Noether')
ORDER BY s.birth_year;
-- Results: Emmy Noether (1882), Mileva Marić (1875), Yvonne Choquet-Bruhat (1923)

-- ────────────────────────────────────────────────────────────
-- Query 10: Which countries have the most fields of research contributions?
-- ────────────────────────────────────────────────────────────
SELECT c.country_name,
       COUNT(DISTINCT sf.field_id) AS distinct_fields
FROM Country c
JOIN Scientist s ON c.country_id = s.country_id
JOIN Scientist_Field sf ON s.scientist_id = sf.scientist_id
GROUP BY c.country_id, c.country_name
ORDER BY distinct_fields DESC, c.country_name;
-- Results: Britain (6), France/Germany/Sweden/USA (3 each), ...

-- ────────────────────────────────────────────────────────────
-- Query 11: Add an event for at least 1 scientist fulfilling requirements
-- (Events already inserted in Section 10 above — verified here)
